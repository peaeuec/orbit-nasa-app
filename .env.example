# NASA API Key (Get one at api.nasa.gov)
NEXT_PUBLIC_NASA_API_KEY=your_nasa_api_key_here

# Supabase Public Keys (From your Supabase Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Supabase Private Key (CRITICAL: Only for account deletion logic)
# Found under Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_secret_service_role_key